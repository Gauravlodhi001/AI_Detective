# AI Detective Configuration Template
# Copy this file to .env and configure as needed

# Server Port
PORT=3000

# Environment Mode ('development', 'production', 'test')
NODE_ENV=development

# SSRF scanning settings: allows WAPT scans of local/loopback IP ranges (e.g. localhost, 127.0.0.1, ::1)
# NOTE: Only takes effect if NODE_ENV is set to 'development'
ALLOW_LOCAL_SCANS=true

# JWT Signing Secret (must be at least 16 characters)
JWT_SECRET=ai-detective-super-secret-key-12345-long-key-for-security

# Anthropic Claude API Key (optional, for AI-assisted vulnerability analysis)
# CLAUDE_API_KEY=your-api-key-here

# Admin Dashboard credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin12345

# Report Encryption Key (must be a 64-character hex string)
REPORT_ENCRYPTION_KEY=68656c6c6f20656e6372797074696f6e206b6579207365637265742031323334
