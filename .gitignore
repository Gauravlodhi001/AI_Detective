.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
*.log

# Diagnostic test files and PDFs in the root
*.pdf
test_leak.pdf

# IDE/Editor configurations
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp

# OS generated files
Thumbs.db
ehthumbs.db
Desktop.ini
.DS_Store
