# Dependency directories
node_modules/

# User uploads & target clone directories (entire folders ignored)
uploads/
cloned_repos/

# Local scan reports folder (completely ignored to prevent leaking vulnerabilities, PDF exports, or session cookies)
reports/

# Temporary scratch and test scripts
scratch/

